# 环境变量配置示例
# 复制此文件为 .env 并填入实际值（.env 已在 .gitignore 中，不会被提交）

# ============ DeepSeek API（与 node-vercel-starter 相同）============

AI_API_KEY=as-xxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro

# 构建时强制全量重建摘要（可选）
# AI_SUMMARY_FULL=1

# 缓存丢失时从线上站点拉取已有 summaries.json（可选）
# SUMMARIES_FALLBACK_URL=https://acongm.com

# ============ 前端实时 API（浏览器侧，不含 Key）============

VUEPRESS_AI_SUMMARY_API=https://api.acongm.com/api/ai/summary

# ============ GitHub Actions / Vercel ============

# 在 GitHub Secrets / Vercel 环境变量中配置：
# - AI_API_KEY
# - AI_BASE_URL（可选）
# - AI_MODEL（可选）
# - VUEPRESS_AI_SUMMARY_API（可选，覆盖默认 API 地址）
# - ACONGM_VUEPRESS（GitHub Pages 部署 PAT）

# ============ 本地开发 ============

TZ=Asia/Shanghai
NODE_VERSION=20

# ============ 本地测试摘要生成 ============

# AI_API_KEY=as-xxx node tools/generate-summaries.mjs
# AI_API_KEY=as-xxx node tools/generate-summaries.mjs --full
