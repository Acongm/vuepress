# 环境变量配置示例
# 复制此文件为 .env 并填入实际值（.env 已在 .gitignore 中，不会被提交）

# ============ DeepSeek API（构建期摘要 build:ai:v1）============

AI_API_KEY=as-xxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro

# 构建时强制全量重建摘要（可选）
# AI_SUMMARY_FULL=1

# 缓存丢失时从线上站点拉取已有 summaries-v1.json（可选）
SUMMARIES_FALLBACK_URL=https://www.acongm.com

# ============ 前端运行时 API（浏览器侧，不含 Key）============

# 本地开发：走 dev server 代理 /api -> api.acongm.com，避免 CORS
# 开发模式会忽略绝对 URL（即使 .env 里写了生产地址也会强制走代理）
VUEPRESS_AI_CHAT_API=/api/ai/v1/chat/stream
VUEPRESS_AI_SUMMARY_API=/api/ai/summary

# 生产构建 / Vercel 环境变量（不要加引号）：
# VUEPRESS_AI_CHAT_API=https://api.acongm.com/api/ai/v1/chat/stream

# Chat 请求扩展字段
# - context.scope: article | module
# - context.pagePath / moduleKey / title / tags
# - enableWebSearch: true 时由服务端持 API Key 联网检索

# ============ GitHub Actions / Vercel ============

# 在 GitHub Secrets / Vercel 环境变量中配置：
# - AI_API_KEY
# - AI_BASE_URL（可选）
# - AI_MODEL（可选）
# - VUEPRESS_AI_CHAT_API（生产用绝对 URL）
# - ACONGM_VUEPRESS（GitHub Pages 部署 PAT）

# ============ 本地开发 ============

TZ=Asia/Shanghai
NODE_VERSION=24

# ============ 本地测试 ============

# npm run build:ai:v1
# AI_SUMMARY_DRY_RUN=1 npm run build:ai:v1
# npm run verify:incremental-ai
